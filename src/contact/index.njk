<!-- Hero "Email support" CTA opens the FreeScout widget by clicking its
     launcher (#fsw-btn). Polls briefly because the widget script is
     async; gives up after ~3s. -->
<script>
	document.querySelectorAll("[data-open-chat]").forEach((trigger) => {
		trigger.addEventListener("click", () => {
			let attempts = 0;
			const tryOpen = () => {
				const launcher = document.getElementById("fsw-btn");
				if (launcher) {
					launcher.click();
				} else if (attempts++ < 30) {
					setTimeout(tryOpen, 100);
				}
			};
			tryOpen();
		});
	});
</script>

