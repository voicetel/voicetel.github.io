			<thead><tr><th scope="col">Field</th><th scope="col">Example</th></tr></thead>
			<tbody>
				<tr><td>Access key ID</td><td><code>AKIA…</code></td></tr>
				<tr><td>Secret access key</td><td><em>(your secret — write-only)</em></td></tr>
				<tr><td>Region</td><td><code>us-east-1</code></td></tr>
				<tr><td>Voice</td><td><code>Joanna</code></td></tr>
				<tr><td>Engine</td><td><code>neural</code></td></tr>
			</tbody>
		</table>
	</div>
	<p><strong>Popular voices:</strong></p>
	<div class="table-container">
		<table class="data-table">
			<thead><tr><th scope="col">Name</th><th scope="col">Voice value</th><th scope="col">Notes</th></tr></thead>
			<tbody>
				<tr><td>Joanna</td><td><code>Joanna</code></td><td>Default US English female; platform default if voice left blank</td></tr>
				<tr><td>Matthew</td><td><code>Matthew</code></td><td>US English male</td></tr>
				<tr><td>Ruth</td><td><code>Ruth</code></td><td>US English female (neural)</td></tr>
