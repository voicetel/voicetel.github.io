            "type": "string",
            "example": "Your API Key"
          },
          "dn": {
            "type": "string",
            "example": "2015551234"
          },
          "callername": {
            "type": "string",
            "example": "Caller Name"
          },
          "addressid": {
            "type": "string",
            "example": "addressid from validateAddress"
          }
        }
      },
      "validateAndProvision": {
        "required": [
          "address1",
          "apikey",
          "callername",
          "city",
          "dn",
          "state",
          "zip"
        ],
        "type": "object",
        "properties": {
