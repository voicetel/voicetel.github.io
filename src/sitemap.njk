---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/0.9">
{%- for page in collections.all -%}
{%- if page.url and not page.data.eleventyExcludeFromCollections and not page.url.startsWith("/docs/api/") and page.url != "/404.html" %}
	<url>
		<loc>{{ site.url }}{{ page.url }}</loc>
		<lastmod>{{ page.date.toISOString().split("T")[0] }}</lastmod>
		{%- if page.url == "/" %}
		<changefreq>weekly</changefreq>
		<priority>1.0</priority>
		{%- else %}
		<changefreq>monthly</changefreq>
		<priority>0.7</priority>
		{%- endif %}
	</url>
{%- endif -%}
{%- endfor %}
{#- Hand-list the redoc-rendered API pages since they aren't Eleventy collections. -#}
{%- for spec in ["voiceml", "account", "auth", "acl", "messaging", "numbers", "iNumbering", "iNumbering-porting", "e911", "gateways", "csp", "info"] %}
	<url>
		<loc>{{ site.url }}/docs/api/{{ spec }}/</loc>
		<changefreq>monthly</changefreq>
		<priority>0.6</priority>
	</url>
{%- endfor %}
</urlset>
