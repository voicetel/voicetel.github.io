---
layout: layouts/page.njk
title: "Contact"
description: "Contact VoiceTel for sales, support, billing, porting, partnerships, legal, press, and technical integration questions."
---

<p class="eyebrow">Contact</p>
<h1>Contact Us.</h1>
<p class="lede">We'd love to hear from you.</p>
<p class="hero-actions">
	<button type="button" class="btn btn-primary" data-open-chat>Email Support</button>
	<a class="btn btn-secondary" href="mailto:{{ site.webEmails.sales }}">Email Sales</a>
	<a class="btn btn-secondary" href="mailto:{{ site.webEmails.compliance }}">Email Compliance</a>
</p>

<section class="section-block">
	<h2>Offices</h2>
	<div class="offices-grid">
		{%- for office in site.offices %}
		<div class="office">
			<h3 id="office-{{ loop.index }}">{{ office.label }}</h3>
			<address aria-labelledby="office-{{ loop.index }}">
				<p>
					{{ office.street }}<br>
					{{ office.city }}, {{ office.region }} {{ office.postalCode }}
				</p>
				<p>
					<span class="office-label">Phone</span> <a href="tel:{{ office.phoneTel }}">{{ office.phone | replace(" ", "&nbsp;") | replace("-", "&#8209;") | safe }}</a><br>
					<span class="office-label">Fax</span> {{ office.fax | replace(" ", "&nbsp;") | replace("-", "&#8209;") | safe }}
				</p>
			</address>
			<iframe
				class="office-map"
				title="Map of {{ office.label }} office"
				src="https://maps.google.com/maps?output=embed&z=15&q={{ (office.street + ', ' + office.city + ', ' + office.region + ' ' + office.postalCode) | urlencode }}"
				loading="lazy"
				referrerpolicy="no-referrer-when-downgrade"></iframe>
		</div>
		{%- endfor %}
	</div>
</section>

