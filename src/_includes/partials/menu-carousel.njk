<section
	class="menu-carousel"
	aria-roledescription="carousel"
	aria-label="Product overview"
	data-menu-carousel
>
	<div class="menu-carousel-track" data-carousel-track aria-live="polite">
		{%- for item in site.menuCarousel %}
		<article
			class="menu-carousel-slide{% if item.isHero %} menu-carousel-slide--hero{% endif %}"
			data-slide-index="{{ loop.index0 }}"
			aria-roledescription="slide"
			aria-label="{{ loop.index }} of {{ site.menuCarousel | length }}: {{ item.title }}"
			{%- if loop.index0 !== 0 %} inert{% endif %}
		>
			<div class="container">
				<p class="menu-carousel-eyebrow">{{ item.tagline }}</p>
				{%- if item.isHero %}
				<h1 class="menu-carousel-title menu-carousel-title--hero">{{ item.title }}</h1>
				{%- else %}
				<h2 class="menu-carousel-title">{{ item.title }}</h2>
				{%- endif %}
				<p class="menu-carousel-description">{{ item.description }}</p>
				<p class="menu-carousel-actions">
					<a class="btn btn-primary" href="{{ item.href }}">{{ item.cta }}{% if not item.isHero %} &rarr;{% endif %}</a>
					{%- if item.secondaryHref %}
					<a class="btn btn-secondary" href="{{ item.secondaryHref }}">{{ item.secondaryCta }}</a>
					{%- endif %}
				</p>
			</div>
		</article>
		{%- endfor %}
	</div>
	<div class="menu-carousel-controls">
		<button
			type="button"
			class="menu-carousel-arrow"
			data-carousel-prev
			aria-label="Previous slide"
		>&larr;</button>
		<ol class="menu-carousel-dots" data-carousel-dots>
			{%- for item in site.menuCarousel %}
			<li>
				<button
					type="button"
					class="menu-carousel-dot"
					data-carousel-dot="{{ loop.index0 }}"
					aria-label="Go to slide {{ loop.index }}: {{ item.title }}"
					{%- if loop.index0 === 0 %} aria-current="true"{% endif %}
				></button>
			</li>
			{%- endfor %}
		</ol>
		<button
			type="button"
			class="menu-carousel-arrow"
			data-carousel-next
			aria-label="Next slide"
		>&rarr;</button>
		<button
			type="button"
			class="menu-carousel-pause"
			data-carousel-pause
			aria-label="Pause auto-advance"
			aria-pressed="false"
		>
			<svg data-pause-icon viewBox="0 0 16 16" width="14" height="14" aria-hidden="true" focusable="false"><rect x="4" y="3" width="3" height="10" fill="currentColor"/><rect x="9" y="3" width="3" height="10" fill="currentColor"/></svg>
			<svg data-play-icon viewBox="0 0 16 16" width="14" height="14" aria-hidden="true" focusable="false" hidden><path d="M4 3 L13 8 L4 13 Z" fill="currentColor"/></svg>
			<span class="visually-hidden" data-pause-label>Pause auto-advance</span>
		</button>
	</div>
</section>
