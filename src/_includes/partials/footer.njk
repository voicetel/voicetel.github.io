<footer class="footer">
	<div class="container">
		<div class="footer-grid">
			<div class="footer-col">
				<div class="footer-brand">{{ site.brand }}</div>
				<p class="footer-tagline">{{ site.tagline }}</p>
			</div>
			{%- for group in site.footerNav %}
				<div class="footer-col">
					<h2 class="footer-heading">{{ group.label }}</h2>
					<ul class="footer-links">
						{%- for item in group.items %}
						<li><a href="{{ item.href }}">{{ item.label }}</a></li>
						{%- endfor %}
					</ul>
				</div>
			{%- endfor %}
		</div>
		<div class="footer-meta">
			<small>&copy; {% year %} {{ site.brand }}. All rights reserved.</small>
			<small>POPs: {{ site.pops | join(" · ") }}</small>
		</div>
	</div>
</footer>
