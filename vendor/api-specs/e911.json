          "address1",
          "apikey",
          "city",
          "state",
          "zip"
        ],
        "type": "object",
        "properties": {
          "apikey": {
            "type": "string",
            "example": "Your API Key"
          },
          "address1": {
            "type": "string",
            "example": "411 HACKENSACK AVENUE"
          },
          "address2": {
            "type": "string",
            "example": "STE 200"
          },
          "city": {
            "type": "string",
            "example": "HACKENSACK"
          },
          "state": {
            "type": "string",
            "example": "NJ"
          },
          "zip": {
            "type": "string",
            "example": "07601"
          }
