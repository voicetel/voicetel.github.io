<footer class="footer">
	<div class="container">
		<div class="footer-grid">
			<div class="footer-col">
				<div class="footer-brand">
					<span class="footer-brand-icon" aria-hidden="true">{% icon "phone-square" %}</span>
					<span class="footer-brand-text">{{ site.brand }}</span>
				</div>
				<p class="footer-tagline">{{ site.tagline }}</p>
				<p class="footer-actions">
					<a class="btn btn-primary" href="{{ site.loginUrl }}">Sign in</a>
					<a class="btn btn-secondary" href="/signup/">Sign up</a>
				</p>
			</div>
			{%- for group in site.footerNav %}
				<div class="footer-col{% if group.columns == 2 %} footer-col--wide{% endif %}">
					<div class="footer-heading-row">
						<h2 class="footer-heading">{{ group.label }}</h2>
						{%- if group.cta %}
						<a class="footer-heading-cta" href="{{ group.cta.href }}">
							{%- if group.cta.icon %}<span class="footer-quick-icon" aria-hidden="true">{% icon group.cta.icon %}</span>{%- endif %}
							{{ group.cta.label }}
						</a>
						{%- endif %}
					</div>
					<ul class="footer-links{% if group.columns == 2 %} footer-links--two-col{% endif %}">
						{%- for item in group.items %}
						<li><a href="{{ item.href }}">{{ item.label }}</a></li>
						{%- endfor %}
					</ul>
				</div>
			{%- endfor %}
		</div>
		<div class="footer-meta">
			<small>&copy; 1999&ndash;{% year %} <a class="footer-legal-link" href="/about/">{{ site.legalName }}</a>. All rights reserved.</small>
			<small><a class="footer-pops-link" href="/status/">POPs: {{ site.pops | join(" · ") }}</a></small>
		</div>
	</div>
</footer>
