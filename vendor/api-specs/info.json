{
  "openapi": "3.1.1",
  "paths": {
    "/v2.1/info/cnam/": {
      "post": {
        "summary": "Caller ID Name Lookup",
        "security": [
          {
            "apikey": []
          }
        ],
        "operationId": "infoCnam",
        "description": "Returns the Caller ID Name (CNAM) for a 10-digit telephone number. Requires CNAM service to be enabled on the account.",
        "requestBody": {
          "description": "Body for caller id name lookup.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/cnamRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/errorResponse"
                }
              }
            },
            "description": "Bad Request or service not enabled (POST /v2.1/info/cnam/)."
          },
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/cnamResponse"
                }
              }
            },
            "description": "OK response from info cnam."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/errorResponse"
                }
              }
            },
            "description": "Unauthorized response from info cnam."
          }
        },
        "tags": [
          "Info"
        ]
      }
    },
    "/v2.1/info/lrn/": {
      "post": {
        "summary": "Location Routing Number Lookup",
        "security": [
          {
            "apikey": []
          }
        ],
        "operationId": "infoLrn",
        "description": "Returns the Location Routing Number (LRN) and carrier information for a destination number. Both dst and cid must be 10-digit NPANXXXXXX format.",
        "requestBody": {
          "description": "Body for location routing number lookup.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/lrnRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/errorResponse"
                }
              }
            },
            "description": "Bad request response from info lrn."
          },
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/lrnResponse"
                }
              }
            },
            "description": "OK response from info lrn."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/errorResponse"
                }
              }
            },
            "description": "Unauthorized response from info lrn."
          }
        },
        "tags": [
          "Info"
        ]
      }
    },
    "/v2.1/info/resporg/": {
      "post": {
        "summary": "Toll-Free RespOrg Lookup",
        "security": [
          {
            "apikey": []
          }
        ],
        "operationId": "infoRespOrg",
        "description": "Returns the Responsible Organization (RespOrg) ID for a toll-free telephone number. Requires LRN service to be enabled on the account.",
        "requestBody": {
          "description": "Body for toll-free resporg lookup.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/resporgRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/errorResponse"
                }
              }
            },
            "description": "Bad Request or service not enabled (POST /v2.1/info/resporg/)."
          },
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/resporgResponse"
                }
              }
            },
            "description": "OK response from info resp org."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/errorResponse"
                }
              }
            },
            "description": "Unauthorized response from info resp org."
          }
        },
        "tags": [
          "Info"
        ]
      }
    }
  },
  "servers": [
    {
      "url": "https://api.voicetel.com"
    }
  ],
  "components": {
    "schemas": {
      "lrnRequest": {
        "description": "Request body for the lrn operation.",
        "properties": {
          "cid": {
            "description": "Calling party number in NPANXXXXXX format.",
            "type": "integer",
            "example": 2015551234
          },
          "dst": {
            "description": "Destination number in NPANXXXXXX format.",
            "type": "integer",
            "example": 2125551234
          },
          "apikey": {
            "type": "string",
            "example": "Your API Key"
          }
        },
        "type": "object",
        "required": [
          "apikey",
          "cid",
          "dst"
        ]
      },
      "lrnData": {
        "properties": {
          "LOCAL": {
            "description": "Y or N.",
            "type": "string",
            "example": "N"
          },
          "LRN": {
            "description": "Location Routing Number in 11-digit format.",
            "type": "string",
            "example": "12125550000"
          },
          "CITY": {
            "type": "string",
            "example": "NEW YORK"
          },
          "LATA": {
            "description": "Local Access and Transport Area.",
            "type": "string",
            "example": "132"
          },
          "STATE": {
            "type": "string",
            "example": "NY"
          },
          "JURISDICTION": {
            "type": "string",
            "example": "INTERSTATE"
          },
          "LECTYPE": {
            "description": "Local Exchange Carrier type.",
            "type": "string",
            "example": "CLEC"
          },
          "LEC": {
            "description": "Local Exchange Carrier name.",
            "type": "string",
            "example": "LEVEL 3"
          },
          "RC": {
            "description": "Rate Center.",
            "type": "string",
            "example": "NWYRCYZN01"
          },
          "OCN": {
            "description": "Operating Company Number.",
            "type": "string",
            "example": "9101"
          }
        },
        "type": "object",
        "description": "LRN result. All fields are strings and may be empty. Field names derived from the XML response structure in lrn2::query()."
      },
      "resporgResponse": {
        "description": "Response wrapper for the resporg operation.",
        "properties": {
          "status": {
            "type": "string",
            "example": "Success"
          },
          "RespOrg": {
            "example": {
              "8005551234": "WSOX"
            },
            "type": "object",
            "description": "Object where the key is the 10-digit toll-free number and the value is the RespOrg ID string.",
            "additionalProperties": {
              "type": "string"
            }
          },
          "statusCode": {
            "type": "string",
            "example": "200"
          }
        },
        "type": "object",
        "required": [
          "statusCode",
          "status",
          "RespOrg"
        ]
      },
      "cnamResponse": {
        "description": "Response wrapper for the cnam operation.",
        "properties": {
          "status": {
            "type": "string",
            "example": "Success"
          },
          "cnam": {
            "description": "Registered Caller ID Name for the telephone number.",
            "type": "string",
            "example": "VOICETEL"
          },
          "statusCode": {
            "type": "string",
            "example": "200"
          }
        },
        "type": "object",
        "required": [
          "statusCode",
          "status",
          "cnam"
        ]
      },
      "cnamRequest": {
        "description": "Request body for the cnam operation.",
        "properties": {
          "cid": {
            "description": "10-digit telephone number in NPANXXXXXX format.",
            "type": "integer",
            "example": 2015551234
          },
          "apikey": {
            "type": "string",
            "example": "Your API Key"
          }
        },
        "type": "object",
        "required": [
          "apikey",
          "cid"
        ]
      },
      "lrnResponse": {
        "description": "Response wrapper for the lrn operation.",
        "properties": {
          "lrn": {
            "$ref": "#/components/schemas/lrnData"
          },
          "status": {
            "type": "string",
            "example": "Success"
          },
          "statusCode": {
            "type": "string",
            "example": "200"
          }
        },
        "type": "object",
        "required": [
          "statusCode",
          "status",
          "lrn"
        ]
      },
      "errorResponse": {
        "description": "Response wrapper for the error operation.",
        "properties": {
          "status": {
            "type": "string",
            "example": "Error"
          },
          "message": {
            "type": "string",
            "example": "Field Required: cid"
          },
          "statusCode": {
            "type": "string",
            "example": "400"
          }
        },
        "type": "object",
        "required": [
          "statusCode",
          "status",
          "message"
        ]
      },
      "resporgRequest": {
        "description": "Request body for the resporg operation.",
        "properties": {
          "tn": {
            "description": "10-digit toll-free number in NPANXXXXXX format.",
            "type": "integer",
            "example": 8005551234
          },
          "apikey": {
            "type": "string",
            "example": "Your API Key"
          }
        },
        "type": "object",
        "required": [
          "apikey",
          "tn"
        ]
      }
    },
    "securitySchemes": {
      "apikey": {
        "description": "apikey security scheme.",
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "info": {
    "license": {
      "name": "Apache 2.0",
      "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
    },
    "description": "Info Services",
    "title": "Info API",
    "contact": {
      "email": "support@voicetel.com"
    },
    "version": "v2.1.6"
  },
  "tags": [
    {
      "name": "Info",
      "description": "Lookups (CNAM, LRN, Resp Org)."
    }
  ]
}