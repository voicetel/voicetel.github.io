          "apikey": {
            "type": "string",
            "example": "Your API Key"
          },
          "dn": {
            "type": "string",
            "example": "2015551234"
          }
        }
      },
      "apikey": {
        "required": [
          "apikey"
        ],
        "type": "object",
        "properties": {
          "apikey": {
            "type": "string",
            "example": "Your API Key"
          }
        }
      },
      "validateAddress": {
