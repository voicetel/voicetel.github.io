{
  "paths": {
    "/v2.1/e911/provisionAddress/": {
      "post": {
        "requestBody": {
          "description": "Body for provision e911 address.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/provisionAddressRequest"
              }
            }
          },
          "required": true
        },
        "operationId": "e911ProvisionAddress",
        "description": "Provisions an e911 address to a telephone number using a pre-validated addressid. The dn must be a number owned by the account.",
        "responses": {
          "200": {
            "description": "Address provisioned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/provisionAddressResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized or number not on account (POST /v2.1/e911/provisionAddress/).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/errorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Provisioning failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/faultResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request response from e 911 provision address.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/errorResponse"
                }
              }
            }
          }
        },
        "summary": "Provision e911 Address",
        "security": [
          {
            "apikey": []
          }
        ],
        "tags": [
          "e911"
        ]
      }
    },
    "/v2.1/e911/queryAll/": {
      "post": {
        "requestBody": {
          "description": "Body for query all e911 records.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/apikeyRequest"
              }
            }
          },
          "required": true
        },
        "operationId": "e911QueryAll",
        "description": "Returns all e911 records provisioned for telephone numbers on the account.",
        "responses": {
          "200": {
            "description": "Records found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/queryAllResponse"
                }
              }
            }
          },
          "404": {
            "description": "No e911 records found for account",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/errorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized response from e 911 query all.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/errorResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request response from e 911 query all.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/errorResponse"
                }
              }
            }
          }
        },
        "summary": "Query All e911 Records",
        "security": [
          {
            "apikey": []
          }
        ],
        "tags": [
          "e911"
        ]
      }
    },
    "/v2.1/e911/queryRecord/": {
      "post": {
        "requestBody": {
          "description": "Body for query e911 record.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/dnRequest"
              }
            }
          },
          "required": true
        },
        "operationId": "e911QueryRecord",
        "description": "Returns the e911 record provisioned for a specific telephone number on the account.",
        "responses": {
          "200": {
            "description": "Record found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/queryRecordResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized or number not on account (POST /v2.1/e911/queryRecord/).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/errorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Query failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/faultResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request response from e 911 query record.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/errorResponse"
                }
              }
            }
          }
        },
        "summary": "Query e911 Record",
        "security": [
          {
            "apikey": []
          }
        ],
        "tags": [
          "e911"
        ]
      }
    },
    "/v2.1/e911/removeRecord/": {
      "post": {
        "requestBody": {
          "description": "Body for remove e911 record.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/dnRequest"
              }
            }
          },
          "required": true
        },
        "operationId": "e911RemoveRecord",
        "description": "Removes the e911 record provisioned for a specific telephone number on the account.",
        "responses": {
          "200": {
            "description": "Record removed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/removeRecordResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized or number not on account (POST /v2.1/e911/removeRecord/).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/errorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Removal failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/faultResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request response from e 911 remove record.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/errorResponse"
                }
              }
            }
          }
        },
        "summary": "Remove e911 Record",
        "security": [
          {
            "apikey": []
          }
        ],
        "tags": [
          "e911"
        ]
      }
    },
    "/v2.1/e911/validateAddress/": {
      "post": {
        "requestBody": {
          "description": "Body for validate e911 address.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/validateAddressRequest"
              }
            }
          },
          "required": true
        },
        "operationId": "e911ValidateAddress",
        "description": "Validates a street address for e911 provisioning. Returns a validated address entry including an addressid for use with provisionAddress.",
        "responses": {
          "200": {
            "description": "Address validated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/validateAddressResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized response from e 911 validate address.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/errorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Address validation failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/faultResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request response from e 911 validate address.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/errorResponse"
                }
              }
            }
          }
        },
        "summary": "Validate e911 Address",
        "security": [
          {
            "apikey": []
          }
        ],
        "tags": [
          "e911"
        ]
      }
    },
    "/v2.1/e911/validateAndProvision/": {
      "post": {
        "requestBody": {
          "description": "Body for validate and provision e911 address.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/validateAndProvisionRequest"
              }
            }
          },
          "required": true
        },
        "operationId": "e911ValidateAndProvision",
        "description": "Combines validateAddress and provisionAddress in a single call. The dn must be a number owned by the account.",
        "responses": {
          "200": {
            "description": "Address validated and provisioned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/provisionAddressResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized or number not on account (POST /v2.1/e911/validateAndProvision/).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/errorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Validation or provisioning failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/faultResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request response from e 911 validate and provision.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/errorResponse"
                }
              }
            }
          }
        },
        "summary": "Validate and Provision e911 Address",
        "security": [
          {
            "apikey": []
          }
        ],
        "tags": [
          "e911"
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "e911Entry": {
        "description": "e911 provisioning record. The sms field is always removed before returning. Known fields shown; additional fields may be present depending on the operation.",
        "type": "object",
        "properties": {
          "city": {
            "type": "string",
            "example": "HACKENSACK"
          },
          "address2": {
            "type": "string",
            "example": "STE 200"
          },
          "dn": {
            "description": "Telephone number in 11-digit format (1+NPANXXXXXX).",
            "type": "string",
            "example": "12015551234"
          },
          "zip": {
            "type": "string",
            "example": "07601"
          },
          "state": {
            "type": "string",
            "example": "NJ"
          },
          "address1": {
            "type": "string",
            "example": "411 HACKENSACK AVENUE"
          },
          "addressid": {
            "description": "Validated address identifier from the provisioning service.",
            "type": "integer",
            "example": 123456
          },
          "callername": {
            "type": "string",
            "example": "JOHN DOE"
          }
        },
        "additionalProperties": true
      },
      "removeRecordResponse": {
        "description": "Response wrapper for the remove record operation.",
        "type": "object",
        "properties": {
          "entry_removed": {
            "$ref": "#/components/schemas/e911Entry"
          },
          "statusCode": {
            "type": "string",
            "example": "200"
          },
          "status": {
            "type": "string",
            "example": "Success"
          }
        },
        "required": [
          "statusCode",
          "status",
          "entry_removed"
        ]
      },
      "errorResponse": {
        "description": "Response wrapper for the error operation.",
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Field Required: dn"
          },
          "statusCode": {
            "type": "string",
            "example": "400"
          },
          "status": {
            "type": "string",
            "example": "Error"
          }
        },
        "required": [
          "statusCode",
          "status",
          "message"
        ]
      },
      "faultResponse": {
        "description": "Response wrapper for the fault operation.",
        "type": "object",
        "properties": {
          "message": {
            "description": "Fault string returned by the e911 provisioning service.",
            "type": "string",
            "example": "Address not found"
          },
          "statusCode": {
            "type": "string",
            "example": "409"
          },
          "status": {
            "type": "string",
            "example": "Error"
          }
        },
        "required": [
          "statusCode",
          "status",
          "message"
        ]
      },
      "validateAndProvisionRequest": {
        "description": "Request body for the validate and provision operation.",
        "type": "object",
        "properties": {
          "city": {
            "type": "string",
            "example": "HACKENSACK"
          },
          "address2": {
            "type": "string",
            "example": "STE 200"
          },
          "dn": {
            "type": "string",
            "example": "2015551234"
          },
          "zip": {
            "type": "string",
            "example": "07601"
          },
          "state": {
            "type": "string",
            "example": "NJ"
          },
          "callername": {
            "type": "string",
            "example": "JOHN DOE"
          },
          "apikey": {
            "type": "string",
            "example": "Your API Key"
          },
          "address1": {
            "type": "string",
            "example": "411 HACKENSACK AVENUE"
          }
        },
        "required": [
          "apikey",
          "dn",
          "callername",
          "address1",
          "city",
          "state",
          "zip"
        ]
      },
      "apikeyRequest": {
        "description": "Request body for the apikey operation.",
        "type": "object",
        "properties": {
          "apikey": {
            "type": "string",
            "example": "Your API Key"
          }
        },
        "required": [
          "apikey"
        ]
      },
      "dnRequest": {
        "description": "Request body for the dn operation.",
        "type": "object",
        "properties": {
          "apikey": {
            "type": "string",
            "example": "Your API Key"
          },
          "dn": {
            "description": "10-digit telephone number in NPANXXXXXX format.",
            "type": "string",
            "example": "2015551234"
          }
        },
        "required": [
          "apikey",
          "dn"
        ]
      },
      "validateAddressResponse": {
        "description": "Response wrapper for the validate address operation.",
        "type": "object",
        "properties": {
          "entry_valid": {
            "$ref": "#/components/schemas/e911Entry"
          },
          "statusCode": {
            "type": "string",
            "example": "200"
          },
          "status": {
            "type": "string",
            "example": "Success"
          }
        },
        "required": [
          "statusCode",
          "status",
          "entry_valid"
        ]
      },
      "queryAllResponse": {
        "description": "Response wrapper for the query all operation.",
        "type": "object",
        "properties": {
          "entry_all": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/e911Entry"
            },
            "example": []
          },
          "statusCode": {
            "type": "string",
            "example": "200"
          },
          "status": {
            "type": "string",
            "example": "Success"
          }
        },
        "required": [
          "statusCode",
          "status",
          "entry_all"
        ]
      },
      "queryRecordResponse": {
        "description": "Response wrapper for the query record operation.",
        "type": "object",
        "properties": {
          "entry_query": {
            "$ref": "#/components/schemas/e911Entry"
          },
          "statusCode": {
            "type": "string",
            "example": "200"
          },
          "status": {
            "type": "string",
            "example": "Success"
          }
        },
        "required": [
          "statusCode",
          "status",
          "entry_query"
        ]
      },
      "provisionAddressRequest": {
        "description": "Request body for the provision address operation.",
        "type": "object",
        "properties": {
          "apikey": {
            "type": "string",
            "example": "Your API Key"
          },
          "addressid": {
            "description": "Address ID from a prior validateAddress call.",
            "type": "integer",
            "example": 123456
          },
          "dn": {
            "type": "string",
            "example": "2015551234"
          },
          "callername": {
            "type": "string",
            "example": "JOHN DOE"
          }
        },
        "required": [
          "apikey",
          "dn",
          "callername",
          "addressid"
        ]
      },
      "provisionAddressResponse": {
        "description": "Response wrapper for the provision address operation.",
        "type": "object",
        "properties": {
          "entry_added": {
            "$ref": "#/components/schemas/e911Entry"
          },
          "statusCode": {
            "type": "string",
            "example": "200"
          },
          "status": {
            "type": "string",
            "example": "Success"
          }
        },
        "required": [
          "statusCode",
          "status",
          "entry_added"
        ]
      },
      "validateAddressRequest": {
        "description": "Request body for the validate address operation.",
        "type": "object",
        "properties": {
          "city": {
            "type": "string",
            "example": "HACKENSACK"
          },
          "address2": {
            "type": "string",
            "example": "STE 200"
          },
          "zip": {
            "type": "string",
            "example": "07601"
          },
          "state": {
            "type": "string",
            "example": "NJ"
          },
          "apikey": {
            "type": "string",
            "example": "Your API Key"
          },
          "address1": {
            "type": "string",
            "example": "411 HACKENSACK AVENUE"
          }
        },
        "required": [
          "apikey",
          "address1",
          "city",
          "state",
          "zip"
        ]
      }
    },
    "securitySchemes": {
      "apikey": {
        "description": "apikey security scheme.",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "servers": [
    {
      "url": "https://api.voicetel.com"
    }
  ],
  "info": {
    "contact": {
      "email": "support@voicetel.com"
